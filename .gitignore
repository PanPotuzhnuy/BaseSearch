# Rust build output
/target/

# Packaged application builds. Keep the public Windows binaries in the repo,
# but never commit local databases created beside the executable.
/dist/*
!/dist/BaseSearch/
!/dist/BaseSearch/BaseSearch.exe
!/dist/BaseSearch/base-search-cli.exe
!/dist/BaseSearch/README.txt
/dist/BaseSearch/data/
/release_packages/

# Local application data and SQLite sidecar files
/data/
*.db
*.sqlite
*.sqlite3
*.duckdb
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm

# Source datasets and generated exports
*.xlsx
*.xls
*.xlsb
*.csv

# Local configuration, logs, and temporary files
.env
.env.*
*.log
*.tmp
*.temp

# Public documentation policy
*.md
!README.md
!LICENSE*.md

# Local planning drafts and internal audits
/docs/
/audit/

# Editor and OS files
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
